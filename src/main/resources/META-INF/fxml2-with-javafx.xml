<!--
    Optional extension points that are only activated when the bundled JavaFX plugin
    (com.intellij.javafx) is present.
-->
<idea-plugin>
    <actions>
        <!--
            When the JavaFX plugin is present, also insert "FXML 2.0 File" into
            JavaFxCreateActions (the group that contains "FXML File"), right after it.
            The action is already registered in plugin.xml under id="NewFxml2File";
            we reference it here to add a second group membership without duplicating it.
        -->
        <reference ref="NewFxml2File">
            <add-to-group group-id="JavaFxCreateActions" anchor="after" relative-to-action="NewFxmlFile"/>
        </reference>
    </actions>
</idea-plugin>
